# ---- Ara Sales backend — PRODUCTION (Azure) ----
# Copy these as Azure App Service "Application settings" (or a Key Vault). Do NOT
# commit real values. Every secret below should come from Key Vault in practice.

# HTTP
NODE_ENV=production
# Azure App Service injects PORT automatically; the app reads it. Leave unset,
# or set to match if self-hosting.
# PORT=8080
# Comma-separated allowed origins = your deployed web admin URL(s).
CORS_ORIGINS=https://ara-sales-web.azurestaticapps.net

# MySQL (Azure Database for MySQL — Flexible Server)
DB_HOST=your-server.mysql.database.azure.com
DB_PORT=3306
DB_USER=araadmin
DB_PASSWORD=__set_in_key_vault__
DB_NAME=ara_sales
DB_SSL=true

# Auth
JWT_SECRET=__set_a_long_random_secret_in_key_vault__
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
# DEV_OTP is ignored in production (NODE_ENV=production), but keep it unset.
DEV_OTP=
BCRYPT_ROUNDS=12
MIN_PASSWORD_LENGTH=8
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
FORGOT_MAX_ATTEMPTS=3
FORGOT_WINDOW_MINUTES=15

# Email (Gmail SMTP, or swap to Azure Communication Services later)
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=__set_in_key_vault__
MAIL_FROM_NAME=Ara Sales

# File storage — DEFAULT: store photos in MySQL (no Storage account needed).
# Photos are compressed (~40-120 KB) and served at /api/photos/:key.
STORAGE_DRIVER=mysql
# Used to build photo URLs for the mysql/local drivers — set to the API's URL.
PUBLIC_BASE_URL=https://ara-sales-api.azurewebsites.net
# --- OR offload photos to Azure Blob (set STORAGE_DRIVER=azure above) ---
AZURE_STORAGE_CONNECTION_STRING=__set_in_key_vault_if_using_azure__
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=visit-photos

# Platform
TRUST_PROXY=1
# Run migrations automatically on boot so there's no separate release step.
AUTO_MIGRATE=true

# Business rules / incentive config (cap OFF by default per spec)
INCENTIVE_MULTIPLIER=1
INCENTIVE_CAP_ENABLED=false
INCENTIVE_MAX_AMOUNT=
GEOFENCE_RADIUS_M=150
VISIT_CODE_TTL_SECONDS=90

# Visit-photo retention (~2 months). Old photos auto-deleted to cap Blob cost;
# visit audit records are kept. 0 = never delete.
PHOTO_RETENTION_DAYS=60
RETENTION_SWEEP_HOURS=24
