{
  "name": "ara-sales-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Ara Sales — Node/Express/MySQL API for sales-rep monitoring",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js",
    "db:reset": "knex migrate:rollback --all --knexfile knexfile.js && knex migrate:latest --knexfile knexfile.js && knex seed:run --knexfile knexfile.js",
    "purge:photos": "node scripts/purge-photos.js",
    "test": "node --test tests/incentive.test.js tests/visit.test.js",
    "test:unit": "node --test tests/incentive.test.js tests/visit.test.js",
    "test:api": "node --test tests/api.test.js",
    "test:auth": "node --test tests/auth.test.js",
    "test:retention": "node --test tests/retention.test.js"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jimp": "^0.22.12",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
