# ---- Ara Sales backend environment ----
# Copy to .env and fill in. NEVER commit the real .env.

# HTTP
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (web admin, etc.)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=ara_sales

# Auth
# Strong random secret for signing JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Primary login is email + PASSWORD. The OTP below is used ONLY for the
# forgot-password recovery flow (emailed via Gmail SMTP).
OTP_TTL_SECONDS=300
# Dev-only fixed reset OTP so the recovery flow is demoable without reading email.
# Accepted ONLY when NODE_ENV=development. Remove/ignore in production.
DEV_OTP=000000

# Password hashing + rate limiting
BCRYPT_ROUNDS=10
MIN_PASSWORD_LENGTH=8
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
FORGOT_MAX_ATTEMPTS=3
FORGOT_WINDOW_MINUTES=15

# Email (Gmail SMTP) — used to send the password-reset OTP.
# Create a Google "App Password" (Account > Security > 2-Step Verification >
# App passwords) and paste the 16-char value below. Placeholders only here.
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
MAIL_FROM_NAME=Ara Sales

# File storage
# Driver:
#   local : disk (dev).
#   mysql : photo bytes in a MySQL LONGBLOB table — NO external store needed,
#           uses the MySQL you already have. Served at /api/photos/:key.
#   azure : Azure Blob Storage (best for large scale).
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
# Public base URL used to build photo links (local + mysql drivers).
PUBLIC_BASE_URL=http://localhost:4000
# Azure Blob Storage (only used when STORAGE_DRIVER=azure). Use a connection
# string OR account name + key. Placeholders only here.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=visit-photos

# --- Deployment / platform ---
# Number of proxies in front of the app (Azure App Service = 1).
TRUST_PROXY=0
# Enable TLS to the database (REQUIRED for Azure Database for MySQL).
DB_SSL=false
# Run pending migrations automatically on boot (handy on PaaS). Never seeds.
AUTO_MIGRATE=false

# Business rules / incentive config (cap is OFF by default per spec)
INCENTIVE_MULTIPLIER=1
INCENTIVE_CAP_ENABLED=false
INCENTIVE_MAX_AMOUNT=
GEOFENCE_RADIUS_M=150
VISIT_CODE_TTL_SECONDS=90

# Visit-photo downscaling (applied before storage). Keeps photos ~40-120 KB so
# MySQL-backed storage stays small. Longest side in px + JPEG quality 0-100.
PHOTO_MAX_DIMENSION=1080
PHOTO_JPEG_QUALITY=60

# Visit-photo retention. After PHOTO_RETENTION_DAYS, a photo's file + DB row are
# deleted (the visit audit record is kept). Caps storage/cost. 0 = never delete.
PHOTO_RETENTION_DAYS=60
# In-process cleanup sweep interval in hours. 0 disables it (use external cron /
# `npm run purge:photos` instead).
RETENTION_SWEEP_HOURS=24
